{
	"nodeModulesDir": "auto",
	"imports": {
		"@triptease/html-jsx": "npm:@triptease/html-jsx@^0.2.7",
		"preact": "npm:preact@^10.29.0",
		"preact-render-to-string": "npm:preact-render-to-string@^6.6.6",
		"sqlite": "https://deno.land/x/sqlite@v3.9.1/mod.ts",
		"hono": "jsr:@hono/hono",
		"@std/assert": "jsr:@std/assert"
	},
	"tasks": {
		"start": "deno run --allow-read --allow-write --allow-net src/index.ts",
		"test": "deno test --allow-read --allow-write src/tests/"
	},
	"compilerOptions": {
		"jsx": "react-jsx",
		"jsxImportSource": "@triptease/html-jsx"
	}
}
