{
  "name": "toggles-root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "deploy:app": "pnpm run --filter=toggles build && pnpm run --filter=toggles deploy",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "nano-staged": "^0.9.0"
  },
  "nano-staged": {
    "*.{js,ts,tsx,jsx,json}": [
      "pnpm -r format:atomic"
    ]
  },
  "packageManager": "pnpm@10.32.1"
}
